<%
  layout('layouts/boilerplate');
%>

<section class="page-stack">
  <section class="hero-band card-glass compact-hero">
    <div>
      <p class="mini-tag">MODULE STATUS</p>
      <h1><%= pageHeading %></h1>
      <p class="hero-copy"><%= pageText %></p>
    </div>
  </section>

  <% if (typeof notes !== 'undefined' && notes.length) { %>
    <section class="section-card card-glass">
      <div class="notes-grid">
        <% notes.forEach((note) => { %>
          <article class="note-card">
            <p class="note-topic"><%= note.topic_name || 'General' %></p>
            <h4><%= note.title %></h4>
            <p><%= note.content.slice(0, 150) %><%= note.content.length > 150 ? '...' : '' %></p>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>
</section>
