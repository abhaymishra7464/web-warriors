<%
  layout('layouts/boilerplate');
%>

<%
  const safeStarterQuestions =
    typeof starterQuestions !== 'undefined' && Array.isArray(starterQuestions)
      ? starterQuestions
      : [];

  const safeResult =
    typeof result !== 'undefined' && result
      ? result
      : null;

  const safeFormData =
    typeof formData !== 'undefined' && formData
      ? formData
      : {};

  const safeImprovementTips =
    safeResult && Array.isArray(safeResult.improvement_tips)
      ? safeResult.improvement_tips
      : [];

  const safeMistakes =
    safeResult && Array.isArray(safeResult.mistakes)
      ? safeResult.mistakes
      : [];

  const safeNextQuestions =
    safeResult &&
    safeResult.smartSuggestions &&
    Array.isArray(safeResult.smartSuggestions.nextQuestions)
      ? safeResult.smartSuggestions.nextQuestions
      : [];

  const safeActionCards =
    safeResult &&
    safeResult.smartSuggestions &&
    Array.isArray(safeResult.smartSuggestions.actionCards)
      ? safeResult.smartSuggestions.actionCards
      : [];
%>

<section class="page-stack">
  <section class="hero-band card-glass compact-hero">
    <div>
      <p class="mini-tag">AI ANALYZER</p>
      <h1>Submit code, detect mistakes, get next LeetCode suggestions</h1>
      <p class="hero-copy">
        Yaha se user question number + code paste karega. System submission save karega, AI analysis generate karega,
        notes banayega, reminders create karega aur next similar questions suggest karega.
      </p>
    </div>
  </section>

  <section class="dashboard-grid-2 analyzer-grid">
    <article class="card-glass section-card">
      <div class="section-head">
        <div>
          <p class="card-label">Submit for review</p>
          <h2>Analyzer form</h2>
        </div>
      </div>

      <% if (error) { %>
        <div class="auth-alert dashboard-alert"><%= error %></div>
      <% } %>

      <form class="planner-form-grid analyzer-form" action="/analyzer" method="POST">
        <div class="field-grid two-col two-col-dashboard">
          <div class="field-group">
            <label for="platform">Platform</label>
            <input
              id="platform"
              name="platform"
              type="text"
              value="<%= safeFormData.platform || 'LeetCode' %>"
              readonly
            />
          </div>

          <div class="field-group">
            <label for="questionId">LeetCode Question No.</label>
            <input
              id="questionId"
              name="questionId"
              type="text"
              placeholder="eg. 121"
              value="<%= safeFormData.questionId || '' %>"
              required
            />
          </div>
        </div>

        <div class="field-grid two-col two-col-dashboard">
          <div class="field-group">
            <label for="language">Language</label>
            <select id="language" name="language" required>
              <% ['Java', 'C++', 'Python', 'JavaScript'].forEach((lang) => { %>
                <option value="<%= lang %>" <%= safeFormData.language === lang ? 'selected' : '' %>><%= lang %></option>
              <% }) %>
            </select>
          </div>

          <div class="field-group">
            <label>Quick tip</label>
            <div class="inline-help">
              Bas question number aur code enough hai. AI us question ke logic, mistakes,
              learned concepts, aur next similar questions suggest karega.
            </div>
          </div>
        </div>

        <div class="field-group">
          <label for="code">Paste your solution</label>
          <textarea
            id="code"
            name="code"
            rows="16"
            placeholder="Paste your code here"
            required
          ><%= safeFormData.code || '' %></textarea>
        </div>

        <button type="submit" class="primary-link-btn form-submit-btn">Analyze with AI</button>
      </form>
    </article>

    <article class="card-glass section-card">
      <div class="section-head">
        <div>
          <p class="card-label">Starter question links</p>
          <h2>Practice set</h2>
        </div>
      </div>

      <% if (safeStarterQuestions.length) { %>
        <div class="feed-list">
          <% safeStarterQuestions.forEach((question) => { %>
            <article class="feed-item">
              <div class="feed-item-top">
                <h4><%= question.title %></h4>
                <% if (question.difficulty) { %>
                  <span class="badge"><%= question.difficulty %></span>
                <% } %>
              </div>

              <% if (question.reason) { %>
                <p><%= question.reason %></p>
              <% } %>

              <% if (question.url) { %>
                <a href="<%= question.url %>" target="_blank" rel="noopener noreferrer">Open Question</a>
              <% } %>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-mini">
          <h4>No starter links yet</h4>
          <p>Planner create karne ke baad yaha topic based starter questions dikhenge.</p>
        </div>
      <% } %>
    </article>
  </section>

  <% if (safeResult && safeResult.isCorrectCode) { %>
    <div class="auth-success dashboard-alert">
      Code correct hai — learned concepts notes automatically save ho gaye.
    </div>
  <% } else if (safeResult && safeMistakes.length) { %>
    <div class="auth-alert dashboard-alert">
      Code me mistakes mili — detailed mistake notes save ho gaye.
    </div>
  <% } %>

  <% if (safeResult) { %>
    <section class="dashboard-grid-2 analyzer-grid">
      <article class="card-glass section-card">
        <div class="section-head">
          <div>
            <p class="card-label">Analysis result</p>
            <h2><%= safeResult.sourceLabel || 'AI Result' %></h2>
          </div>
          <span class="status-chip done">
            <%= safeResult.detected_topic || 'Topic' %>
            <% if (safeResult.detected_subtopic) { %>
              • <%= safeResult.detected_subtopic %>
            <% } %>
          </span>
        </div>

        <div class="logic-list">
          <div class="logic-item">
            <h4>Summary</h4>
            <p><%= safeResult.summary || 'Analysis completed.' %></p>
          </div>

          <div class="logic-item">
            <h4>Improvement tips</h4>
            <% if (safeImprovementTips.length) { %>
              <ul class="clean-list">
                <% safeImprovementTips.forEach((tip) => { %>
                  <li><%= tip %></li>
                <% }) %>
              </ul>
            <% } else { %>
              <p>No improvement tips returned.</p>
            <% } %>
          </div>

          <div class="logic-item code-block-item">
            <h4>Corrected code / reviewed code</h4>
            <pre class="code-preview"><code><%= safeResult.corrected_code || 'No reviewed code returned.' %></code></pre>
          </div>
        </div>
      </article>

      <article class="card-glass section-card">
        <div class="section-head">
          <div>
            <p class="card-label">Mistake breakdown</p>
            <h2>What to fix next</h2>
          </div>
        </div>

        <% if (safeMistakes.length) { %>
          <div class="feed-list">
            <% safeMistakes.forEach((item) => { %>
              <article class="feed-item">
                <div>
                  <h4><%= item.title %></h4>
                  <p><%= item.detail %></p>
                </div>
                <span class="severity-badge"><%= item.severity || 'medium' %></span>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-mini">
            <h4>No structured mistakes returned</h4>
            <p>Ye achha sign bhi ho sakta hai agar code correct hai, ya stronger model later try kar sakte ho.</p>
          </div>
        <% } %>
      </article>
    </section>

    <section class="dashboard-grid-2 analyzer-grid">
      <article class="card-glass section-card">
        <div class="section-head">
          <div>
            <p class="card-label">Next LeetCode suggestions</p>
            <h2>Similar questions</h2>
          </div>
        </div>

        <% if (safeNextQuestions.length) { %>
          <div class="feed-list">
            <% safeNextQuestions.forEach((question) => { %>
              <article class="feed-item">
                <div>
                  <h4><%= question.title %></h4>
                  <p>#<%= question.id %> • <%= question.difficulty %></p>
                </div>
                <a href="<%= question.url %>" target="_blank" rel="noreferrer" class="task-link">Solve now</a>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-mini">
            <h4>No suggestions yet</h4>
            <p>AI response aane ke baad yaha similar questions dikhenge.</p>
          </div>
        <% } %>
      </article>

      <article class="card-glass section-card">
        <div class="section-head">
          <div>
            <p class="card-label">Adaptive action cards</p>
            <h2>What system will push next</h2>
          </div>
        </div>

        <% if (safeActionCards.length) { %>
          <div class="logic-list">
            <% safeActionCards.forEach((card) => { %>
              <div class="logic-item">
                <h4><%= card.title %></h4>
                <p><%= card.text %></p>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-mini">
            <h4>No adaptive cards yet</h4>
            <p>Ek analysis run karne ke baad yaha personalized next actions aayenge.</p>
          </div>
        <% } %>
      </article>
    </section>
  <% } %>
</section>