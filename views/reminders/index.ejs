<%
  layout('layouts/boilerplate');
%>

<section class="page-stack">
  <section class="hero-band card-glass compact-hero">
    <div>
      <p class="mini-tag">REMINDER CENTER</p>
      <h1>Practice reminders</h1>
      <p class="hero-copy">Repeated mistakes, weak topics aur pending revision ke reminders yaha aayenge.</p>
    </div>
  </section>

  <section class="section-card card-glass">
    <% if (reminders.length) { %>
      <div class="feed-list">
        <% reminders.forEach((item) => { %>
          <article class="feed-item">
            <div>
              <h4><%= item.title %></h4>
              <p><%= item.message %></p>
            </div>
            <span class="status-chip pending"><%= item.status %></span>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state-box">
        <h4>No reminders yet</h4>
        <p>Planner aur analyzer ke baad reminder engine active ho jayega.</p>
      </div>
    <% } %>
  </section>
</section>
