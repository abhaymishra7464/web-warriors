<%
  layout('layouts/boilerplate');
%>

<section class="page-stack">
  <section class="hero-band card-glass compact-hero">
    <div>
      <p class="mini-tag">AI ANALYZER</p>
      <h1>Submit code, detect mistakes, get next LeetCode suggestions</h1>
      <p class="hero-copy">
        Yaha se user question number + code paste karega. System submission save karega, AI analysis generate karega,
        notes banayega, reminders create karega aur next similar questions suggest karega.
      </p>
    </div>
  </section>

  <section class="dashboard-grid-2 analyzer-grid">
    <article class="card-glass section-card">
      <div class="section-head">
        <div>
          <p class="card-label">Submit for review</p>
          <h2>Analyzer form</h2>
        </div>
      </div>

      <% if (error) { %>
        <div class="auth-alert dashboard-alert"><%= error %></div>
      <% } %>

      <form class="planner-form-grid analyzer-form" action="/analyzer" method="POST">
        <div class="field-grid two-col two-col-dashboard">
          <div class="field-group">
            <label for="platform">Platform</label>
            <select id="platform" name="platform">
              <option value="LeetCode" <%= formData.platform === 'LeetCode' ? 'selected' : '' %>>LeetCode</option>
              <option value="Codeforces" <%= formData.platform === 'Codeforces' ? 'selected' : '' %>>Codeforces</option>
              <option value="Custom Question" <%= formData.platform === 'Custom Question' ? 'selected' : '' %>>Custom Question</option>
            </select>
          </div>
          <div class="field-group">
            <label for="questionId">Question ID / Slug</label>
            <input id="questionId" name="questionId" type="text" placeholder="eg. 1 / two-sum" value="<%= formData.questionId || '' %>">
          </div>
        </div>

        <div class="field-grid two-col two-col-dashboard">
          <div class="field-group">
            <label for="problemTitle">Problem Title</label>
            <input id="problemTitle" name="problemTitle" type="text" placeholder="eg. Two Sum" value="<%= formData.problemTitle || '' %>">
          </div>
          <div class="field-group">
            <label for="topicName">Topic</label>
            <input id="topicName" name="topicName" type="text" placeholder="eg. Array" value="<%= formData.topicName || '' %>">
          </div>
        </div>

        <div class="field-grid two-col two-col-dashboard">
          <div class="field-group">
            <label for="language">Language</label>
            <select id="language" name="language">
              <% ['Java', 'C++', 'Python', 'JavaScript'].forEach((lang) => { %>
                <option value="<%= lang %>" <%= formData.language === lang ? 'selected' : '' %>><%= lang %></option>
              <% }) %>
            </select>
          </div>
          <div class="field-group">
            <label>Quick tip</label>
            <div class="inline-help">Question number aur code enough hai. AI baki context infer karne ki koshish karega.</div>
          </div>
        </div>

        <div class="field-group">
          <label for="code">Paste your solution</label>
          <textarea id="code" name="code" rows="16" placeholder="Paste your code here"><%= formData.code || '' %></textarea>
        </div>

        <button type="submit" class="primary-link-btn form-submit-btn">Analyze with AI</button>
      </form>
    </article>

    <article class="card-glass section-card">
      <div class="section-head">
        <div>
          <p class="card-label">Starter question links</p>
          <h2>Practice set</h2>
        </div>
      </div>

      <% if (starterQuestions?.length) { %>
        <div class="feed-list">
          <% starterQuestions.forEach((question) => { %>
            <article class="feed-item">
              <div>
                <h4><%= question.title %></h4>
                <p>#<%= question.id %> • <%= question.difficulty %></p>
              </div>
              <a href="<%= question.url %>" target="_blank" rel="noreferrer" class="task-link">Open LC</a>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-mini">
          <h4>No starter links yet</h4>
          <p>Planner create karne ke baad yaha topic based starter questions dikhenge.</p>
        </div>
      <% } %>
    </article>
  </section>

  <% if (result) { %>
    <section class="dashboard-grid-2 analyzer-grid">
      <article class="card-glass section-card">
        <div class="section-head">
          <div>
            <p class="card-label">Analysis result</p>
            <h2><%= result.sourceLabel %></h2>
          </div>
          <span class="status-chip done"><%= result.detected_topic %> • <%= result.detected_subtopic %></span>
        </div>

        <div class="logic-list">
          <div class="logic-item">
            <h4>Summary</h4>
            <p><%= result.summary %></p>
          </div>

          <div class="logic-item">
            <h4>Improvement tips</h4>
            <ul class="clean-list">
              <% result.improvement_tips.forEach((tip) => { %>
                <li><%= tip %></li>
              <% }) %>
            </ul>
          </div>

          <div class="logic-item code-block-item">
            <h4>Corrected code / reviewed code</h4>
            <pre class="code-preview"><code><%= result.corrected_code %></code></pre>
          </div>
        </div>
      </article>

      <article class="card-glass section-card">
        <div class="section-head">
          <div>
            <p class="card-label">Mistake breakdown</p>
            <h2>What to fix next</h2>
          </div>
        </div>

        <% if (result.mistakes?.length) { %>
          <div class="feed-list">
            <% result.mistakes.forEach((item) => { %>
              <article class="feed-item">
                <div>
                  <h4><%= item.title %></h4>
                  <p><%= item.detail %></p>
                </div>
                <span class="severity-badge"><%= item.severity %></span>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-mini">
            <h4>No structured mistakes returned</h4>
            <p>Try another submission or stronger model later.</p>
          </div>
        <% } %>
      </article>
    </section>

    <section class="dashboard-grid-2 analyzer-grid">
      <article class="card-glass section-card">
        <div class="section-head">
          <div>
            <p class="card-label">Next LeetCode suggestions</p>
            <h2>Similar questions</h2>
          </div>
        </div>

        <div class="feed-list">
          <% result.smartSuggestions.nextQuestions.forEach((question) => { %>
            <article class="feed-item">
              <div>
                <h4><%= question.title %></h4>
                <p>#<%= question.id %> • <%= question.difficulty %></p>
              </div>
              <a href="<%= question.url %>" target="_blank" rel="noreferrer" class="task-link">Solve now</a>
            </article>
          <% }) %>
        </div>
      </article>

      <article class="card-glass section-card">
        <div class="section-head">
          <div>
            <p class="card-label">Adaptive action cards</p>
            <h2>What system will push next</h2>
          </div>
        </div>

        <div class="logic-list">
          <% result.smartSuggestions.actionCards.forEach((card) => { %>
            <div class="logic-item">
              <h4><%= card.title %></h4>
              <p><%= card.text %></p>
            </div>
          <% }) %>
        </div>
      </article>
    </section>
  <% } %>
</section>
